{
  "name": "wayfarer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "tsc -b && vite build --configLoader runner",
    "preview": "vite preview",
    "test": "vitest run --configLoader runner",
    "clean:node-tests": "node -e \"require('fs').rmSync('dist-node-tests',{recursive:true,force:true})\"",
    "build:node-tests": "tsc -p tsconfig.node-tests.json",
    "test:node": "npm run clean:node-tests && npm run build:node-tests && node dist-node-tests/tests/node/index.node.test.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.2.0"
  }
}
